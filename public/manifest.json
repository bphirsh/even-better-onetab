{
  "manifest_version": 3,
  "name": "Even Better OneTab",
  "version": "2.1.2",
  "default_locale": "en",
  "description": "__MSG_appDesc__",
  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "background": {
    "service_worker": "sw.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon_16.png",
      "32": "icons/icon_32.png",
      "48": "icons/icon_48.png",
      "128": "icons/icon_128.png"
    }
  },
  "options_ui": {
    "page": "app.html#/settings",
    "open_in_tab": true
  },
  "commands": {
    "store-selected-tabs": {
      "description": "__MSG_cmdStoreSelected__"
    },
    "store-all-tabs": {
      "description": "__MSG_cmdStoreAll__"
    },
    "store-all-in-all-windows": {
      "description": "__MSG_cmdStoreAllWindows__"
    },
    "restore-latest-list": {
      "description": "__MSG_cmdRestoreLatest__"
    },
    "open-lists": {
      "description": "__MSG_cmdOpenLists__"
    }
  },
  "permissions": [
    "contextMenus",
    "storage",
    "tabs",
    "tabGroups",
    "alarms"
  ]
}
