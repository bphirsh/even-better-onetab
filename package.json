{
  "name": "even-better-onetab",
  "version": "2.3.0",
  "description": "Store and restore your tabs in one click — a cleaner, faster OneTab alternative.",
  "private": true,
  "type": "module",
  "repository": "https://github.com/bphirsh/even-better-onetab",
  "license": "MIT",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "package": "rm -f dist.zip && cd dist && zip -r ../dist.zip ./*"
  },
  "dependencies": {
    "svelte-dnd-action": "^0.9.61"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tsconfig/svelte": "^5.0.4",
    "@types/chrome": "^0.0.287",
    "@types/node": "^26.1.1",
    "svelte": "^5.19.0",
    "svelte-check": "^4.1.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.11"
  }
}
